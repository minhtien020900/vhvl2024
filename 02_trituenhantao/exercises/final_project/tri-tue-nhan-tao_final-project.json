{"paragraphs":[{"text":"%pyspark\n\nimport random\nimport matplotlib.pyplot as plt\nimport numpy as np\nfrom IPython.display import clear_output\nimport time\n\nclass NQueensPuzzle:\n    def __init__(self,n,num_queens):\n        \n        self.n =n;\n        self.num_queens=num_queens\n        self.queen_state = self.initial_queen_state()\n        self.frames = []\n        \n    \n    \n    def initial_queen_state(self):\n        columns = random.sample(range(self.n), min(self.num_queens, self.n))\n        state = [-1] * self.n\n        \n        for col in columns:\n            state[col] = random.randint(0, self.n-1)\n            \n        return state\n    \n    def getQueenStates(self):\n        return self.queen_state\n    \n    def count_conflicts(self,row,col):\n        count = 0\n        \n        for i in range(self.n):\n            if i == col or self.queen_state[i] == -1:\n                continue\n            if self.queen_state[i] == row or abs(self.queen_state[i] - row) == abs(i - col):\n                count += 1\n                \n        return count\n\n\n    def find_conflicted_column(self):\n        conflicted_columns = []\n        \n        for col in range(self.n):\n            if self.queen_state[col] == -1:\n                continue\n            \n            row = self.queen_state[col]\n            if self.count_conflicts(row,col) > 0:\n                conflicted_columns.append(col)\n        \n        return random.choice(conflicted_columns) if conflicted_columns else None\n        \n    \n    def find_min_conflict_row(self,col):\n        min_conflicts = float('inf')\n        min_rows = []\n        \n        for row in range(self.n):\n            conflicts = self.count_conflicts(row,col)\n            \n            if conflicts < min_conflicts:\n                min_conflicts = conflicts\n                min_rows = [row]\n            elif conflicts == min_conflicts:\n                min_rows.append(row)\n        \n        return random.choice(min_rows)\n            \n    \n    def drawChessBoard(self,queen_positions):\n        N = len(queen_positions)\n        fig, ax = plt.subplots(figsize=(8, 8))\n        \n        # Vẽ ô bàn cờ (đen - trắng)\n        for i in range(N):\n            for j in range(N):\n                color = \"white\" if (i + j) % 2 == 0 else \"gray\"\n                ax.add_patch(plt.Rectangle((j, N - i - 1), 1, 1, color=color))\n    \n        # Vẽ quân hậu (♛)\n        for col, row in enumerate(self.queen_state):\n            ax.text(col + 0.5, (N - row - 1) + 0.5, '♛', fontsize=30, ha='center', va='center', fontweight='bold',color='red')\n        \n        # Vẽ khung viền bao ngoài\n        ax.add_patch(plt.Rectangle((0, 0), N, N, fill=False, edgecolor='black', linewidth=2))\n    \n        # Thiết lập trục\n        ax.set_xticks([])\n        ax.set_yticks([])\n        ax.set_xlim(0, N)\n        ax.set_ylim(0, N)\n        ax.set_frame_on(False)\n    \n        plt.show()       \n            \n    def draw_chessboard_for_gif_image(self,queen_positions, highlight_from=None, highlight_to=None,conflicts = None, selected_col=None):\n        N = len(queen_positions)\n        fig, ax = plt.subplots(figsize=(8, 8))\n        \n        # Vẽ ô bàn cờ (đen - trắng)\n        for i in range(N):\n            for j in range(N):\n                color = \"white\" if (i + j) % 2 == 0 else \"gray\"\n                ax.add_patch(plt.Rectangle((j, N - i - 1), 1, 1, color=color))\n    \n        # Vẽ quân hậu (♛)\n        for col, row in enumerate(queen_positions):\n            ax.text(col + 0.5, (N - row - 1) + 0.5, '♛', fontsize=40, ha='center', va='center', fontweight='bold',color='red')\n    \n        # Highlight quân hậu di chuyển\n        if highlight_from is not None and highlight_to is not None:\n            col_from, row_from = highlight_from\n            col_to, row_to = highlight_to\n            \n            # Vẽ khung màu xanh cho vị trí cũ\n            ax.add_patch(plt.Rectangle((col_from, N - row_from - 1), 1, 1, edgecolor='black', fill=False, linewidth=3))\n            # Vẽ khung màu xanh lá cho vị trí mới\n            ax.add_patch(plt.Rectangle((col_to, N - row_to - 1), 1, 1, edgecolor='green', fill=False, linewidth=3))\n    \n        # Hiển thị số conflict trên cột được chọn\n        if conflicts is not None and selected_col is not None:\n            for row in range(N):\n                if row == queen_state[selected_col]:  # Bỏ qua ô của hậu hiện tại\n                    continue  \n                ax.text(selected_col + 0.5, (N - row - 1) + 0.5, f'{conflicts[row]}', fontweight='bold',fontsize=15, ha='center', va='center', color='black')\n                \n        # Vẽ khung viền bao ngoài\n        ax.add_patch(plt.Rectangle((0, 0), N, N, fill=False, edgecolor='black', linewidth=3))\n    \n        # Thiết lập trục\n        ax.set_xticks([])\n        ax.set_yticks([])\n        ax.set_xlim(0, N)\n        ax.set_ylim(0, N)\n        ax.set_frame_on(False)\n    \n        self.frames.append([ax])\n        plt.close(fig)\n        # plt.show()\n    ","user":"anonymous","dateUpdated":"2025-02-20T18:31:21+0700","config":{"colWidth":12,"fontSize":11,"enabled":true,"results":{},"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true},"editorMode":"ace/mode/python","lineNumbers":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[]},"apps":[],"jobName":"paragraph_1739891239072_-46418873","id":"20250218-220719_2037814767","dateCreated":"2025-02-18T22:07:19+0700","dateStarted":"2025-02-20T18:31:21+0700","dateFinished":"2025-02-20T18:31:22+0700","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:794"},{"text":"%pyspark\n\nclass MinConflictSolver:\n    \n    def __init__(self):\n        self.puzzle =None;\n        # self.conflict_history = []\n        \n    def train(self, puzzle):\n        self.puzzle = puzzle\n        \n    def solve(self,max_steps = 100):\n        if self.puzzle is None:\n            raise ValueError(\"Chưa huấn luyện solver với puzzle!\")\n    \n        for step in range(max_steps):\n            # Chọn ngẫu nhiên một column đang có conflict, nếu trả về None thì đã tìm được kết quả\n            col = self.puzzle.find_conflicted_column()\n            \n            if col is None:\n                #print(i)\n                return self.puzzle.queen_state\n                \n            conflicts_in_current_column = [self.puzzle.count_conflicts(row, col) for row in range(self.puzzle.n)]\n            \n            # Đây là row mới\n            new_row = self.puzzle.find_min_conflict_row(col)\n            \n            #print(f\"Step {step + 1}: Moving queen in column {col} from row {self.puzzle.queen_state[col]} to row {new_row}\")\n          \n            self.puzzle.draw_chessboard_for_gif_image(self.puzzle.queen_state, highlight_from=(col, self.puzzle.queen_state[col]), highlight_to=(col, new_row),conflicts = conflicts_in_current_column,selected_col = col)\n            \n            self.puzzle.queen_state[col] = new_row\n        #print(i)\n        return self.puzzle.queen_state","user":"anonymous","dateUpdated":"2025-02-20T18:31:49+0700","config":{"colWidth":12,"fontSize":9,"enabled":true,"results":{},"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true},"editorMode":"ace/mode/python","lineNumbers":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[]},"apps":[],"jobName":"paragraph_1739970242722_1563180530","id":"20250219-200402_88291278","dateCreated":"2025-02-19T20:04:02+0700","dateStarted":"2025-02-20T18:31:50+0700","dateFinished":"2025-02-20T18:31:50+0700","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:795"},{"text":"%pyspark\nimport matplotlib.pyplot as plt\nimport numpy as np\n\n\nclass ChessBoardAnimator:\n    def __init__(self,frames = []):\n        self.frames = frames\n\n    def convertFigToImage(self, fig):\n        \"\"\"Chuyển đổi figure của matplotlib thành ảnh PIL\"\"\"\n        fig.canvas.draw()\n        img = Image.frombytes('RGB', fig.canvas.get_width_height(), fig.canvas.tostring_rgb())\n        return img\n\n    def saveGif(self, filename=\"chess_animation.gif\", duration=1500):\n        images = [self.convertFigToImage(ax[0].figure) for ax in self.frames]  # Chuyển subplot thành ảnh\n        images[0].save(filename, save_all=True, append_images=images[1:], duration=duration, loop=0)\n        \n        print(f\"GIF saved at {filename}\")\n","user":"anonymous","dateUpdated":"2025-02-20T18:31:52+0700","config":{"colWidth":12,"fontSize":9,"enabled":true,"results":{},"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true},"editorMode":"ace/mode/python"},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[]},"apps":[],"jobName":"paragraph_1740034156879_-1752737045","id":"20250220-134916_806515324","dateCreated":"2025-02-20T13:49:16+0700","dateStarted":"2025-02-20T18:31:52+0700","dateFinished":"2025-02-20T18:31:52+0700","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:796"},{"text":"%pyspark\nimport matplotlib.pyplot as plt\nimport numpy as np\nfrom matplotlib.animation import PillowWriter\n\nfrom PIL import Image\n\npuzzle = NQueensPuzzle(5,5)\nqueen_state = puzzle.getQueenStates()\n\npuzzle.drawChessBoard(queen_state)\n\nsolver = MinConflictSolver()\nsolver.train(puzzle)\nsolution = solver.solve(max_steps=100)\n\nchess_board_proccess = ChessBoardAnimator(puzzle.frames)\nchess_board_proccess.saveGif()\n\n\npuzzle.drawChessBoard(solution)","user":"anonymous","dateUpdated":"2025-02-20T18:31:55+0700","config":{"colWidth":12,"fontSize":9,"enabled":true,"results":{"1":{"graph":{"mode":"table","height":1125.67,"optionOpen":false}}},"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true},"editorMode":"ace/mode/python","lineNumbers":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<div style='width:auto;height:auto'><img src=data:image/png;base64, style='width=auto;height:auto'><div>\nGIF saved at chess_animation.gif\n"},{"type":"HTML","data":"<div style='width:auto;height:auto'><img src=data:image/png;base64, style='width=auto;height:auto'><div>\n"}]},"apps":[],"jobName":"paragraph_1739892918711_-1780364533","id":"20250218-223518_748853413","dateCreated":"2025-02-18T22:35:18+0700","dateStarted":"2025-02-20T18:31:55+0700","dateFinished":"2025-02-20T18:31:56+0700","status":"FINISHED","progressUpdateIntervalMs":500,"$$hashKey":"object:797"}],"name":"tri-tue-nhan-tao/final-project","id":"2KMCUF2K8","noteParams":{},"noteForms":{},"angularObjects":{"spark:shared_process":[]},"config":{"isZeppelinNotebookCronEnable":false,"looknfeel":"default","personalizedMode":"false"},"info":{}}